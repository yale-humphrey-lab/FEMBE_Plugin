    <load_controller id="2" type="loadcurve">
      <interpolate>LINEAR</interpolate>
      <points>
        <loadpoint>0,0</loadpoint>
        <loadpoint>1,0.0</loadpoint>
        <loadpoint>2,0.0</loadpoint>
        <loadpoint>5,0.36</loadpoint>
      </points>
    </load_controller>
  </LoadData>
  <Output>
    <plotfile type="vtk">
      <var type="displacement" />
      <var type="relative volume" />
      <var type="stress" />
      <var type="SPR stress" />
      <var type="SPR principal stress" />
      <var type="deformation gradient" />
      <var type="strain energy density" />
      <var type="acceleration" />
      <var type="velocity" />
    </plotfile>
  </Output>
</febio_spec>